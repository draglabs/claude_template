  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'printf \"%s canary fired cwd=%s stdin=\" \"$(date -u +%FT%TZ)\" \"$PWD\" >> /tmp/claude-sessionstart.log; cat >> /tmp/claude-sessionstart.log; printf \"\\n\" >> /tmp/claude-sessionstart.log'"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/sync-framework.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-reorient.sh"
